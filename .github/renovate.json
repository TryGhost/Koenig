{
  "extends": [
    "github>tryghost/renovate-config"
  ],
  "ignoreDeps": [
    "codecov/codecov-action"
  ],
  "packageRules": [
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "groupName": "rollup + plugins",
      "matchPackageNames": [
        "/^rollup/"
      ]
    },
    {
      "groupName": "lexical",
      "matchPackageNames": [
        "/^lexical/",
        "/^@lexical/"
      ]
    },
    {
      "groupName": "vitest",
      "matchPackageNames": [
        "/^vitest/",
        "/^@vitest/"
      ]
    },
    {
      "matchPackageNames": ["@tryghost/mobiledoc-kit"],
      "enabled": false
    },
    {
      "groupName": "react",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom",
        "eslint-plugin-react-hooks"
      ],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
