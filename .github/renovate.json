{
  "extends": [
    "github>tryghost/renovate-config"
  ],
  "ignoreDeps": [
    "codecov/codecov-action"
  ],
  "packageRules": [
{
      "groupName": "rollup + plugins",
      "packagePatterns": [
        "^rollup"
      ]
    },
    {
      "groupName": "lexical",
      "packagePatterns": [
        "^lexical",
        "^@lexical"
      ],
      "enabled": false
    },
    {
      "groupName": "vitest",
      "packagePatterns": [
        "^vitest",
        "^@vitest"
      ]
    },
    {
      "groupName": "react",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom",
        "eslint-plugin-react-hooks"
      ],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
